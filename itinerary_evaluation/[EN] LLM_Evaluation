    "def get_route(spot_a, spot_b, conn):\n",
    "    \"\"\"Return route data in either direction for a pair of locations.\"\"\"\n",
    "    query = \"\"\"\n",
    "        SELECT r.distance_km, r.transit_min\n",
    "        FROM relation_data AS r\n",
    "        JOIN locations AS origin ON r.origin_id = origin.id\n",
    "        JOIN locations AS destination ON r.destination_id = destination.id\n",
    "        WHERE origin.name = ? AND destination.name = ?\n",
    "    \"\"\"\n",
    "\n",
    "    result = pd.read_sql_query(query, conn, params=(spot_a, spot_b))\n",
    "    if result.empty:\n",
    "        result = pd.read_sql_query(query, conn, params=(spot_b, spot_a))\n",
    "    return result\n",
    "\n",
    "\n",
    "def check_route_evaluation(itinerary, conn):\n",
    "    \"\"\"Evaluate travel between every consecutive pair of itinerary stops.\"\"\"\n",
    "    if len(itinerary) <= 1:\n",
    "        print(\"Only one location is listed; route validation is unnecessary.\")\n",
    "        return\n",
    "\n",
    "    print(\"--- Route and Travel-Time Validation ---\")\n",
    "\n",
    "    total_travel_minutes = 0\n",
    "    has_issue = False\n",
    "\n",
    "    for index in range(len(itinerary) - 1):\n",
    "        spot_a = itinerary[index][\"spot\"].strip()\n",
    "        spot_b = itinerary[index + 1][\"spot\"].strip()\n",
    "        route = get_route(spot_a, spot_b, conn)\n",
    "\n",
    "        if route.empty:\n",
    "            print(\n",
    "                f\"No route information found for [{spot_a} -> {spot_b}].\"\n",
    "            )\n",
    "            has_issue = True\n",
    "            continue\n",
    "\n",
    "        distance_km = float(route.at[0, \"distance_km\"])\n",
    "        transit_minutes = int(route.at[0, \"transit_min\"])\n",
    "        total_travel_minutes += transit_minutes\n",
    "\n",
    "        if transit_minutes >= 45 or distance_km >= 10.0:\n",
    "            print(f\"Travel inefficiency warning: [{spot_a} -> {spot_b}]\")\n",
    "            print(\n",
    "                f\"Distance: {distance_km:.1f} km; \"\n",
    "                f\"public-transit time: {transit_minutes} minutes.\"\n",
    "            )\n",
    "            has_issue = True\n",
    "        else:\n",
    "            print(\n",
    "                f\"Reasonable route: [{spot_a} -> {spot_b}] \"\n",
    "                f\"({distance_km:.1f} km, {transit_minutes} minutes by transit)\"\n",
    "            )\n",
    "\n",
    "    print(\n",
    "        f\"\\nTotal accumulated public-transit time: \"\n",
    "        f\"{total_travel_minutes} minutes\"\n",
    "    )\n",
    "\n",
    "    if total_travel_minutes > 120:\n",
    "        print(\n",
    "            \"Warning: Total travel time exceeds two hours. \"\n",
    "            \"Consider optimizing the route.\"\n",
    "        )\n",
    "        has_issue = True\n",
    "\n",
    "    if not has_issue:\n",
    "        print(\"Excellent: The route is geographically efficient.\")\n",
    "\n",
    "    print(\"-\" * 50)\n",
    "    print()\n"
   ]
