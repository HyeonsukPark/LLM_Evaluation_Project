    "def check_quality(response, conn, max_daily_hours=8):\n",
    "    \"\"\"Check location validity and total scheduled visit duration.\"\"\"\n",
    "    case_id = response[\"case_id\"]\n",
    "    itinerary_df = pd.DataFrame(response[\"itinerary\"])\n",
    "\n",
    "    known_locations = set(\n",
    "        pd.read_sql(\"SELECT name FROM locations\", conn)[\"name\"].tolist()\n",
    "    )\n",
    "    invalid_locations = sorted(\n",
    "        set(itinerary_df.loc[~itinerary_df[\"spot\"].isin(known_locations), \"spot\"])\n",
    "    )\n",
    "    total_visit_hours = itinerary_df[\"spent_time\"].sum()\n",
    "\n",
    "    print(f\"--- Evaluation Report: [{case_id}] ---\")\n",
    "\n",
    "    if invalid_locations:\n",
    "        print(\n",
    "            \"Error: The itinerary contains locations that are not in the \"\n",
    "            f\"grounding database: {invalid_locations}\"\n",
    "        )\n",
    "\n",
    "    if total_visit_hours > max_daily_hours:\n",
    "        print(\n",
    "            f\"Error: The itinerary includes {total_visit_hours} hours of visits, \"\n",
    "            f\"which exceeds the recommended maximum of {max_daily_hours} hours.\"\n",
    "        )\n",
    "\n",
    "    if not invalid_locations and total_visit_hours <= max_daily_hours:\n",
    "        print(\"Good: The itinerary uses valid locations and has a feasible duration.\")\n",
    "\n",
    "    print()\n"
   ]
