   "source": [
    "import sqlite3\n",
    "import pandas as pd\n",
    "\n",
    "# Use a file-based SQLite database so the grounding data persists across runs.\n",
    "db_path = \"travel_grounding.db\"\n",
    "conn = sqlite3.connect(db_path)\n",
    "cursor = conn.cursor()\n",
    "\n",
    "# Recreate the tables to make this setup cell safe to run multiple times.\n",
    "cursor.executescript(\n",
    "    '''\n",
    "    DROP TABLE IF EXISTS constraints;\n",
    "    DROP TABLE IF EXISTS relation_data;\n",
    "    DROP TABLE IF EXISTS locations;\n",
    "\n",
    "    CREATE TABLE locations (\n",
    "        id INTEGER PRIMARY KEY,\n",
    "        name TEXT NOT NULL UNIQUE,\n",
    "        type TEXT NOT NULL,\n",
    "        district TEXT NOT NULL,\n",
    "        required_time INTEGER NOT NULL\n",
    "    );\n",
    "\n",
    "    CREATE TABLE relation_data (\n",
    "        origin_id INTEGER NOT NULL,\n",
    "        destination_id INTEGER NOT NULL,\n",
    "        distance_km REAL NOT NULL,\n",
    "        transit_min INTEGER NOT NULL,\n",
    "        PRIMARY KEY (origin_id, destination_id),\n",
    "        FOREIGN KEY (origin_id) REFERENCES locations(id),\n",
    "        FOREIGN KEY (destination_id) REFERENCES locations(id)\n",
    "    );\n",
    "\n",
    "    CREATE TABLE constraints (\n",
    "        location_id INTEGER PRIMARY KEY,\n",
    "        closed_day INTEGER NOT NULL CHECK (closed_day BETWEEN 0 AND 7),\n",
    "        open_time TEXT NOT NULL,\n",
    "        close_time TEXT NOT NULL,\n",
    "        require_reservation INTEGER NOT NULL CHECK (require_reservation IN (0, 1)),\n",
    "        FOREIGN KEY (location_id) REFERENCES locations(id)\n",
    "    );\n",
    "    '''\n",
    ")\n"
   ]
