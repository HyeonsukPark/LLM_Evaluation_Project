   "cell_type": "code",
   "execution_count": 1,
   "id": "a423b626-c398-4a50-888a-f85eff8a5063",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "<sqlite3.Cursor at 0x2ac83efe440>"
